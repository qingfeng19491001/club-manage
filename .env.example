# 配置文件
spring.profiles.active=prod

# 数据库配置 (生产使用环境变量)
DB_HOST=mysql
DB_PORT=3306
DB_NAME=club_manage
DB_USER=club
DB_PASSWORD=club123

# JWT 密钥 (生产必须设置，必须至少256位)
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-256-bits-long-for-hs256

# MySQL root 密码
MYSQL_ROOT_PASSWORD=admin123
MYSQL_USER=club
MYSQL_PASSWORD=club123
